# Solana RPC endpoints (primary + fallback required — see spec B.4)
SOLANA_RPC_PRIMARY=https://api.devnet.solana.com
SOLANA_RPC_FALLBACK=https://api.devnet.solana.com

# Path to backend keypair JSON (pays register_nullifier rent ~0.00089 SOL each)
# Alert fires if balance drops below 1 SOL (~1100 proofs remaining)
BACKEND_KEYPAIR_PATH=./keys/backend-keypair.json

# ES256 P-256 JWT signing key — PEM format
# In production: load from HSM or hardware wallet, NEVER from disk
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem

# Solana program ID — set after first devnet deploy
PROGRAM_ID=11111111111111111111111111111111

# VK version string — bump on every circuit recompile (see spec A.6)
VK_VERSION=1

# Path to compiled circuit artifact (from circuit team: nargo compile output)
CIRCUIT_PATH=../circuit/target/circuit.json

# Path to verification key (from circuit team: bb write_vk output)
VK_PATH=../circuit/target/vk

# Server
PORT=3000
NODE_ENV=development
